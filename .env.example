# =============================================================================
# AWS Configuration
# =============================================================================
AWS_PROFILE=your-aws-profile
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# =============================================================================
# S3 Storage Configuration
# =============================================================================
# S3_VECTORS_BUCKET: AWS S3 Vector service bucket (keep as-is for AWS service compatibility)
S3_VECTORS_BUCKET=your-vector-embedding-bucket
# Shared media storage bucket (for uploads, datasets, artifacts)
SHARED_BUCKET_NAME=videolake-shared-media
# Embeddings output bucket
EMBEDDINGS_BUCKET_NAME=videolake-embeddings-xyz123

# =============================================================================
# Bedrock Model Configuration
# =============================================================================
BEDROCK_TEXT_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_MM_MODEL=amazon.titan-embed-image-v1
TWELVELABS_MODEL=twelvelabs.marengo-embed-2-7-v1:0
TWELVELABS_API_KEY=your-twelvelabs-api-key

# =============================================================================
# Vector Database Endpoints (Optional - deployed via Terraform)
# =============================================================================
# OpenSearch Serverless
# OPENSEARCH_DOMAIN=your-opensearch-domain
# OPENSEARCH_ENDPOINT=https://your-opensearch-endpoint.us-east-1.aoss.amazonaws.com

# Qdrant (ECS Fargate or EC2)
# QDRANT_URL=http://your-qdrant-lb:6333
# QDRANT_API_KEY=your-qdrant-api-key

# LanceDB API (ECS Fargate)
# LANCEDB_URL=http://your-lancedb-lb:8000

# =============================================================================
# Processing Configuration
# =============================================================================
BATCH_SIZE_TEXT=100
BATCH_SIZE_VIDEO=10
BATCH_SIZE_VECTORS=1000
VIDEO_SEGMENT_DURATION=5
MAX_VIDEO_DURATION=7200
POLL_INTERVAL=30
MAX_CONCURRENT_REQUESTS=10

# =============================================================================
# AWS Client Configuration
# =============================================================================
AWS_MAX_RETRIES=3
AWS_TIMEOUT_SECONDS=60
AWS_CONNECT_TIMEOUT=10

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
STRUCTURED_LOGGING=true
LOG_FORMAT=json

# =============================================================================
# Video Ingestion Pipeline (Optional - if deployed)
# =============================================================================
# INGESTION_STATE_MACHINE_ARN=arn:aws:states:us-east-1:123456789012:stateMachine:videolake-ingestion-pipeline
# INGESTION_NOTIFICATION_EMAIL=your-email@example.com

# =============================================================================
# API Server Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# =============================================================================
# Frontend Configuration
# =============================================================================
VITE_API_BASE_URL=http://localhost:8000
VITE_ENABLE_ANALYTICS=false

# =============================================================================
# Development & Testing
# =============================================================================
# Set to 'true' to use moto for local AWS mocking in tests
USE_MOTO_MOCKS=false
# Set to 'true' to enable debug mode
DEBUG=false