# =============================================================================
# Terraform Configuration Template
# =============================================================================
#
# INSTRUCTIONS:
# 1. Copy this file to terraform.tfvars:
#    cp terraform.tfvars.example terraform.tfvars
#
# 2. Fill in your AWS configuration (region, project name)
#
# 3. OPTIONALLY enable additional vector store backends:
#    - Uncomment the backend you want to deploy
#    - Set its value to true
#    - Save the file
#
# 4. Run terraform apply (no -var flags needed when using terraform.tfvars)
#
# DEFAULT DEPLOYMENT:
# If you don't create terraform.tfvars or leave backends commented out,
# Terraform will deploy ONLY S3Vector (fast, cheap, perfect for getting started).
#
# =============================================================================

# -----------------------------------------------------------------------------
# Required AWS Configuration
# -----------------------------------------------------------------------------
aws_region   = "us-east-1"  # Change to your preferred AWS region
project_name = "s3vector"   # Change if you want a different project name
environment  = "dev"

# -----------------------------------------------------------------------------
# Optional Vector Store Backends (ALL DISABLED BY DEFAULT)
# -----------------------------------------------------------------------------
# Uncomment and set to true to enable additional backends

# OpenSearch Serverless (AWS-managed, advanced features, ~$50+/month, 10-15 min deploy)
# deploy_opensearch = true

# Qdrant on ECS (high-performance, advanced filtering, ~$20+/month, 5-10 min deploy)
# deploy_qdrant = true

# LanceDB with S3 storage (cheapest option, Arrow-native, ~$5+/month, 5 min deploy)
# deploy_lancedb_s3 = true

# LanceDB with EFS storage (balanced performance/cost, ~$15+/month, 5 min deploy)
# deploy_lancedb_efs = true

# LanceDB with EBS storage (fastest option, ~$30+/month, 5 min deploy)
# deploy_lancedb_ebs = true

#------------------------------------------------------------------------------
# SHARED MEDIA BUCKET (Always Created)
#------------------------------------------------------------------------------
# This bucket is always created for videos, TwelveLabs I/O, datasets, etc.

# Use default name (${project_name}-shared-media) or specify custom:
# shared_bucket_name = "my-custom-shared-bucket"

shared_bucket_enable_versioning  = true
shared_bucket_lifecycle_enabled  = true

# Enable CORS for web uploads (optional)
enable_web_upload = false
web_allowed_origins = [
  "http://localhost:5172",
  "http://localhost:8501"
]

#------------------------------------------------------------------------------
# S3VECTOR CONFIGURATION
#------------------------------------------------------------------------------

s3vector_bucket_name = "s3vector-demo-vectors"

# Default index configuration (created automatically)
# vector_dimension = 1536      # For OpenAI embeddings
# distance_metric = "cosine"   # cosine, euclidean, or dot_product
# vector_data_type = "float32" # float32, float16, or int8

#------------------------------------------------------------------------------
# OPENSEARCH CONFIGURATION (if deploy_opensearch = true)
#------------------------------------------------------------------------------

opensearch_domain_name = "s3vector-demo"

# Instance configuration
opensearch_instance_type  = "or1.medium.search"  # OR1 required for S3Vector
opensearch_instance_count = 2
opensearch_multi_az       = false  # Set true for production

# Authentication
opensearch_enable_auth     = true
opensearch_master_user     = "admin"
opensearch_master_password = "MediaLake-Demo-2024!"  # CHANGE IN PRODUCTION!

#------------------------------------------------------------------------------
# QDRANT CONFIGURATION (if deploy_qdrant = true)
#------------------------------------------------------------------------------

qdrant_deployment_name = "s3vector-demo-qdrant"
qdrant_version = "latest"

# ECS Task sizing
# task_cpu = 2048       # 2 vCPU
# task_memory_mb = 4096 # 4 GB

#------------------------------------------------------------------------------
# LANCEDB CONFIGURATION (if deploy_lancedb_* = true)
#------------------------------------------------------------------------------

lancedb_deployment_name = "s3vector-demo-lancedb"
lancedb_storage_gb = 100

# ECS Task sizing (applies to all LanceDB variants)
# task_cpu = 2048       # 2 vCPU
# task_memory_mb = 4096 # 4 GB

#------------------------------------------------------------------------------
# LEGACY CONFIGURATION (Deprecated)
#------------------------------------------------------------------------------
# These variables are kept for backward compatibility
# New deployments should use shared_bucket_name instead

# data_bucket_name = "media-lake-demo-data"  # Use shared_bucket_name instead

# -----------------------------------------------------------------------------
# Deployment Time & Cost Summary
# -----------------------------------------------------------------------------
# S3Vector only:     < 5 min    ~$0.50/month
# + OpenSearch:      15-20 min  ~$50-60/month
# + Qdrant:          10-15 min  ~$20-30/month
# + LanceDB (S3):    5-10 min   ~$5-10/month
# + LanceDB (EFS):   5-10 min   ~$15-20/month
# + LanceDB (EBS):   5-10 min   ~$30-40/month
#
# Full comparison (all 4): 15-20 min, ~$50-100/month
