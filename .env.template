# S3Vector - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# ENVIRONMENT SETTINGS
# =============================================================================
ENVIRONMENT=development  # development, staging, production, testing
DEBUG=true
LOG_LEVEL=INFO
HOST=localhost
PORT=8501

# =============================================================================
# AWS CONFIGURATION
# =============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_SESSION_TOKEN=  # Optional, for temporary credentials

# S3 Configuration
S3_BUCKET=your-s3vector-bucket
S3_PREFIX=vectors/

# Bedrock Configuration
BEDROCK_MODEL_ID=amazon.titan-embed-text-v1
BEDROCK_MAX_TOKENS=8192

# =============================================================================
# S3VECTOR CONFIGURATION
# =============================================================================
S3VECTOR_ENDPOINT=your_s3vector_endpoint_here
S3VECTOR_ACCESS_KEY=your_s3vector_access_key_here
S3VECTOR_SECRET_KEY=your_s3vector_secret_key_here

# =============================================================================
# MARENGO 2.7 CONFIGURATION
# =============================================================================
# Choose access method: "bedrock" (recommended) or "twelvelabs_api"
MARENGO_ACCESS_METHOD=bedrock

# Bedrock access configuration (recommended for AWS integration)
MARENGO_BEDROCK_MODEL_ID=twelvelabs.marengo-embed-2-7-v1:0
MARENGO_BEDROCK_REGION=us-east-1  # us-east-1, eu-west-1, ap-northeast-2

# TwelveLabs API access configuration (alternative direct API access)
TWELVELABS_API_KEY=your_twelvelabs_api_key_here
TWELVELABS_API_URL=https://api.twelvelabs.io
TWELVELABS_MODEL_NAME=marengo2.7

# Common processing settings
MAX_VIDEO_DURATION=3600  # seconds
SEGMENT_DURATION=5.0     # seconds

# =============================================================================
# OPENSEARCH CONFIGURATION (Optional)
# =============================================================================
OPENSEARCH_ENDPOINT=your_opensearch_endpoint_here
OPENSEARCH_USERNAME=your_opensearch_username_here
OPENSEARCH_PASSWORD=your_opensearch_password_here
OPENSEARCH_INDEX_PREFIX=s3vector

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_REAL_AWS=true
ENABLE_OPENSEARCH_HYBRID=true
ENABLE_VIDEO_UPLOAD=true
ENABLE_COST_ESTIMATION=true
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_ERROR_DASHBOARD=true
ENABLE_ADVANCED_VISUALIZATION=true
ENABLE_MULTI_VECTOR_PROCESSING=true
ENABLE_QUERY_AUTO_DETECTION=true
ENABLE_SEGMENT_NAVIGATION=true

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================
MAX_CONCURRENT_JOBS=8
REQUEST_TIMEOUT=30
MAX_RETRIES=3
CACHE_TTL=3600           # seconds
MAX_MEMORY_USAGE=4096    # MB
ENABLE_CACHING=true
ENABLE_COMPRESSION=true

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
ENABLE_HTTPS=false       # Set to true in production
SESSION_TIMEOUT=3600     # seconds
MAX_UPLOAD_SIZE=500      # MB
ENABLE_CORS=true         # Set to false in production
ENABLE_XSRF_PROTECTION=false  # Set to true in production

# =============================================================================
# UI CONFIGURATION
# =============================================================================
APP_TITLE="S3Vector"
APP_ICON="🔍"
PAGE_LAYOUT=wide
SIDEBAR_STATE=expanded
THEME=light

# =============================================================================
# PROCESSING SETTINGS
# =============================================================================
DEFAULT_PROCESSING_MODE=parallel
DEFAULT_SEGMENT_DURATION=5.0

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_FILE=logs/s3vector.log
LOG_MAX_SIZE=10485760    # 10MB
LOG_BACKUP_COUNT=5

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30  # seconds

# =============================================================================
# DEVELOPMENT SETTINGS (Development Environment Only)
# =============================================================================
# Uncomment these for development
# STREAMLIT_SERVER_HEADLESS=false
# STREAMLIT_SERVER_RUN_ON_SAVE=true
# STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# =============================================================================
# PRODUCTION SETTINGS (Production Environment Only)
# =============================================================================
# Uncomment and configure these for production deployment
# STREAMLIT_SERVER_HEADLESS=true
# STREAMLIT_SERVER_ENABLE_CORS=false
# STREAMLIT_SERVER_ENABLE_XSRF_PROTECTION=true
# STREAMLIT_SERVER_MAX_UPLOAD_SIZE=1000

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit the actual .env file to version control
# 2. Use strong, unique passwords and API keys
# 3. Rotate credentials regularly
# 4. Use AWS IAM roles in production instead of access keys when possible
# 5. Enable HTTPS and proper security settings in production
# 6. Monitor resource usage and adjust performance settings as needed
# 7. Test configuration changes in staging before production deployment
